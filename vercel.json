{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "apps/server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "outputDirectory": "apps/server/dist",
   "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/server/dist/index.mjs",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "OPTIONS"
      ]
    }
  ]
}